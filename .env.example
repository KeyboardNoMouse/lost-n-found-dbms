# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nielostnfound?retryWrites=true&w=majority

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>

# ── Google OAuth (restrict to nie.ac.in domain in Google Cloud Console) ──────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Admin panel ──────────────────────────────────────────────────────────────
# Comma-separated NIE admin email(s)
ADMIN_EMAILS=admin@nie.ac.in
# Client-safe copy (only for showing the Admin nav link — no secrets)
NEXT_PUBLIC_ADMIN_EMAILS=admin@nie.ac.in

# ── Email notifications (SMTP) ───────────────────────────────────────────────
# Optional: if not set, claim notifications are silently skipped.
# For quick setup use Resend (https://resend.com) or Brevo (https://brevo.com).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@nie.ac.in
SMTP_PASS=your-smtp-password
SMTP_FROM="NIE Lost & Found <noreply@nie.ac.in>"

# ── Auto-expiry cron ─────────────────────────────────────────────────────────
# Items older than this many days are marked "expired" by the daily cron job.
ITEM_EXPIRY_DAYS=30
# Secret to protect the /api/cron/expire-items endpoint
CRON_SECRET=<generate with: openssl rand -base64 32>
